{
  "name": "master-canvas",
  "version": "1.0.0",
  "description": "Local-first pre-production canvas for AI video planning, prompts, assets, and handoff packages.",
  "main": "electron/main.cjs",
  "private": false,
  "license": "MIT",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && electron electron/main.cjs",
    "desktop:dir": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "studio.mastercanvas.app",
    "productName": "Master Canvas",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "AudioVideo"
    }
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
